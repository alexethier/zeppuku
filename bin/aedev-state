#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["pyyaml>=6"]
# ///
"""Read/write project state in ~/.aedev/aethier-mcp/state.yaml.

Usage:
    aedev-state get KEY            # print value, empty if missing
    aedev-state set KEY VALUE      # set, creating nested keys as needed
    aedev-state unset KEY          # delete key (and any children)
    aedev-state show               # print whole file
    aedev-state dir                # print (and create) project dir

Keys are dot-separated paths, e.g. `bridge.pid`.
Values are coerced to int/float/bool when they parse cleanly.
"""
from __future__ import annotations

import os
import pathlib
import sys

import yaml

STATE_FILE = pathlib.Path(
    os.path.expanduser("~/.aedev/aethier-mcp/state.yaml")
)


def load() -> dict:
    if not STATE_FILE.exists():
        return {}
    return yaml.safe_load(STATE_FILE.read_text()) or {}


def save(data: dict) -> None:
    STATE_FILE.parent.mkdir(parents=True, exist_ok=True)
    STATE_FILE.write_text(
        yaml.safe_dump(data, default_flow_style=False, sort_keys=True)
    )


def parse_key(key: str) -> list[str]:
    return [k for k in key.split(".") if k]


def get_path(d, keys: list[str]):
    for k in keys:
        if not isinstance(d, dict) or k not in d:
            return None
        d = d[k]
    return d


def set_path(d: dict, keys: list[str], value) -> None:
    for k in keys[:-1]:
        nxt = d.get(k)
        if not isinstance(nxt, dict):
            nxt = {}
            d[k] = nxt
        d = nxt
    d[keys[-1]] = value


def unset_path(d: dict, keys: list[str]) -> bool:
    for k in keys[:-1]:
        nxt = d.get(k)
        if not isinstance(nxt, dict):
            return False
        d = nxt
    return d.pop(keys[-1], None) is not None


def coerce(s: str):
    low = s.lower()
    if low in ("true", "yes"):
        return True
    if low in ("false", "no"):
        return False
    try:
        return int(s)
    except ValueError:
        pass
    try:
        return float(s)
    except ValueError:
        pass
    return s


def main() -> None:
    args = sys.argv[1:]
    if not args:
        sys.exit("usage: aedev-state {get|set|unset|show} ...")

    op = args[0]

    if op == "show":
        sys.stdout.write(
            yaml.safe_dump(load(), default_flow_style=False, sort_keys=True)
        )
        return

    if op == "dir":
        STATE_FILE.parent.mkdir(parents=True, exist_ok=True)
        print(STATE_FILE.parent)
        return

    if op == "get":
        if len(args) != 2:
            sys.exit("usage: aedev-state get KEY")
        v = get_path(load(), parse_key(args[1]))
        if v is not None:
            print(v)
        return

    if op == "set":
        if len(args) != 3:
            sys.exit("usage: aedev-state set KEY VALUE")
        data = load()
        set_path(data, parse_key(args[1]), coerce(args[2]))
        save(data)
        return

    if op == "unset":
        if len(args) != 2:
            sys.exit("usage: aedev-state unset KEY")
        data = load()
        if unset_path(data, parse_key(args[1])):
            save(data)
        return

    sys.exit(f"unknown op: {op}")


if __name__ == "__main__":
    main()
